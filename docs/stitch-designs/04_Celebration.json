{"screenId":"346e6ffe914d4d9aaa2ec169882fa702","projectId":"12231893172607086013","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&amp;family=Be_Vietnam_Pro:wght@400;500;700;900&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"on-primary-container\": \"#4d001e\",\n              \"error-container\": \"#fb5151\",\n              \"background\": \"#fff4f6\",\n              \"primary-fixed\": \"#ff7198\",\n              \"inverse-on-surface\": \"#c58da6\",\n              \"surface\": \"#fff4f6\",\n              \"tertiary-fixed-dim\": \"#edc600\",\n              \"error\": \"#b31b25\",\n              \"primary-fixed-dim\": \"#ff5389\",\n              \"on-primary-fixed\": \"#000000\",\n              \"on-secondary-fixed\": \"#4d2d00\",\n              \"on-primary\": \"#ffeff0\",\n              \"secondary-container\": \"#ffc78a\",\n              \"tertiary-container\": \"#fdd400\",\n              \"outline-variant\": \"#d69db6\",\n              \"on-surface\": \"#492136\",\n              \"surface-container-high\": \"#ffd8e7\",\n              \"secondary\": \"#835000\",\n              \"surface-tint\": \"#b60051\",\n              \"inverse-surface\": \"#220214\",\n              \"outline\": \"#9b687f\",\n              \"surface-dim\": \"#ffc4dd\",\n              \"on-secondary-container\": \"#683e00\",\n              \"on-tertiary-container\": \"#594a00\",\n              \"on-primary-fixed-variant\": \"#5e0027\",\n              \"on-tertiary-fixed\": \"#433700\",\n              \"on-secondary\": \"#fff0e4\",\n              \"on-tertiary-fixed-variant\": \"#645300\",\n              \"surface-container\": \"#ffe0ec\",\n              \"error-dim\": \"#9f0519\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"tertiary\": \"#6d5a00\",\n              \"tertiary-fixed\": \"#fdd400\",\n              \"surface-container-highest\": \"#ffd0e3\",\n              \"on-error\": \"#ffefee\",\n              \"secondary-fixed\": \"#ffc78a\",\n              \"surface-container-low\": \"#ffecf2\",\n              \"inverse-primary\": \"#ff4c85\",\n              \"on-secondary-fixed-variant\": \"#744600\",\n              \"secondary-dim\": \"#734500\",\n              \"surface-variant\": \"#ffd0e3\",\n              \"tertiary-dim\": \"#5f4e00\",\n              \"surface-bright\": \"#fff4f6\",\n              \"on-error-container\": \"#570008\",\n              \"primary\": \"#b60051\",\n              \"on-tertiary\": \"#fff2ce\",\n              \"secondary-fixed-dim\": \"#ffb55c\",\n              \"primary-dim\": \"#a00047\",\n              \"on-background\": \"#492136\",\n              \"on-surface-variant\": \"#7c4d64\",\n              \"primary-container\": \"#ff7198\"\n            },\n            fontFamily: {\n              \"headline\": [\"Plus Jakarta Sans\"],\n              \"body\": [\"Be Vietnam Pro\"],\n              \"label\": [\"Be Vietnam Pro\"]\n            },\n            borderRadius: {\"DEFAULT\": \"1rem\", \"lg\": \"2rem\", \"xl\": \"3rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .bg-radiant-burst {\n            background: radial-gradient(circle at center, rgba(255, 199, 138, 0.3) 0%, rgba(255, 244, 246, 0) 70%);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface font-body text-on-surface selection:bg-primary-container selection:text-on-primary-container min-h-screen\">\n<!-- TopAppBar -->\n<header class=\"bg-[#fff4f6] dark:bg-pink-950/20 fixed top-0 w-full z-50\">\n<nav class=\"flex items-center justify-between px-6 h-16 w-full\">\n<div class=\"flex items-center gap-2\">\n<button class=\"hover:scale-105 transition-transform scale-95 active:duration-100 flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-[#b60051] dark:text-pink-400\" data-icon=\"close\">close</span>\n</button>\n</div>\n<h1 class=\"font-['Plus_Jakarta_Sans'] font-bold tracking-tight text-lg text-[#492136] dark:text-pink-100\">Celebration</h1>\n<div class=\"w-10\"></div> <!-- Spacer for centering -->\n</nav>\n</header>\n<main class=\"relative pt-16 pb-32 min-h-screen flex flex-col items-center justify-center px-8 overflow-hidden\">\n<!-- Radiant Burst Background Element -->\n<div class=\"absolute inset-0 pointer-events-none\">\n<div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] bg-radiant-burst\"></div>\n<!-- Abstract Shapes (Simulating Confetti) -->\n<div class=\"absolute top-[20%] left-[10%] w-12 h-12 rounded-full bg-secondary-container opacity-40 blur-xl\"></div>\n<div class=\"absolute top-[15%] right-[15%] w-16 h-16 rounded-xl bg-tertiary-container opacity-30 rotate-12 blur-lg\"></div>\n<div class=\"absolute bottom-[30%] left-[15%] w-10 h-10 rounded-full bg-primary-container opacity-20 blur-md\"></div>\n</div>\n<div class=\"relative z-10 flex flex-col items-center text-center\">\n<!-- Hero Icon Component -->\n<div class=\"relative mb-8\">\n<!-- Decorative Confetti Circles -->\n<div class=\"absolute -top-4 -left-4 w-6 h-6 bg-tertiary rounded-full opacity-60\"></div>\n<div class=\"absolute -top-2 right-0 w-4 h-4 bg-secondary rounded-full opacity-60\"></div>\n<div class=\"absolute bottom-2 -right-6 w-5 h-5 bg-primary rounded-full opacity-40\"></div>\n<div class=\"w-32 h-32 bg-surface-container-highest rounded-full flex items-center justify-center shadow-[0_10px_40px_rgba(73,33,54,0.06)] scale-110\">\n<span class=\"material-symbols-outlined text-primary text-6xl\" data-icon=\"task_alt\" style=\"font-variation-settings: 'FILL' 1;\">task_alt</span>\n</div>\n</div>\n<!-- Celebration Text -->\n<p class=\"font-headline text-[11px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-3\">Milestone Achieved</p>\n<h2 class=\"font-headline text-5xl md:text-6xl font-extrabold tracking-tight text-primary leading-tight mb-4\">\n                You did it!\n            </h2>\n<p class=\"max-w-xs mx-auto text-on-surface-variant text-lg leading-relaxed mb-12\">\n                Your dedication is paying off. You've completed your daily goals and earned a new badge!\n            </p>\n<!-- Success Card (Bento Style) -->\n<div class=\"w-full max-w-sm bg-surface-container-low rounded-xl p-6 mb-12 relative overflow-hidden text-left\">\n<div class=\"flex items-center gap-4\">\n<div class=\"w-12 h-12 bg-tertiary-container rounded-lg flex items-center justify-center\">\n<span class=\"material-symbols-outlined text-on-tertiary-container\" data-icon=\"workspace_premium\" style=\"font-variation-settings: 'FILL' 1;\">workspace_premium</span>\n</div>\n<div>\n<h4 class=\"font-headline font-bold text-on-surface\">Goal Crusher</h4>\n<p class=\"text-sm text-on-surface-variant\">5-Day Streak Award</p>\n</div>\n</div>\n</div>\n<!-- Primary Action -->\n<button class=\"group relative px-10 py-4 bg-gradient-to-br from-primary to-primary-container text-surface-container-lowest font-headline font-bold rounded-lg shadow-lg hover:scale-105 active:scale-95 transition-all duration-300\">\n                Return to Home\n            </button>\n</div>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-8 pb-6 pt-2 bg-[#fff4f6]/80 dark:bg-pink-950/80 backdrop-blur-xl rounded-t-[3rem] shadow-[0_-10px_40px_rgba(73,33,54,0.06)]\">\n<!-- Home (Inactive) -->\n<a class=\"flex flex-col items-center justify-center text-[#492136] dark:text-pink-300/60 opacity-60 hover:bg-[#ffecf2] dark:hover:bg-pink-900 transition-colors scale-110 duration-300 ease-out\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"home\">home</span>\n<span class=\"font-['Be_Vietnam_Pro'] text-[11px] font-bold uppercase tracking-widest\">Home</span>\n</a>\n<!-- Tasks (Active State based on the \"Goal\" completion context) -->\n<a class=\"flex flex-col items-center justify-center bg-[#ffd8e7] dark:bg-pink-800 text-[#b60051] dark:text-pink-100 rounded-full py-2 px-4 transition-all duration-300\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"task_alt\" style=\"font-variation-settings: 'FILL' 1;\">task_alt</span>\n<span class=\"font-['Be_Vietnam_Pro'] text-[11px] font-bold uppercase tracking-widest\">Tasks</span>\n</a>\n<!-- Rewards (Inactive) -->\n<a class=\"flex flex-col items-center justify-center text-[#492136] dark:text-pink-300/60 opacity-60 hover:bg-[#ffecf2] dark:hover:bg-pink-900 transition-colors\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"workspace_premium\">workspace_premium</span>\n<span class=\"font-['Be_Vietnam_Pro'] text-[11px] font-bold uppercase tracking-widest\">Rewards</span>\n</a>\n<!-- Profile (Inactive) -->\n<a class=\"flex flex-col items-center justify-center text-[#492136] dark:text-pink-300/60 opacity-60 hover:bg-[#ffecf2] dark:hover:bg-pink-900 transition-colors\" href=\"#\">\n<span class=\"material-symbols-outlined mb-1\" data-icon=\"person\">person</span>\n<span class=\"font-['Be_Vietnam_Pro'] text-[11px] font-bold uppercase tracking-widest\">Profile</span>\n</a>\n</nav>\n</body></html>"}
