{"screenId":"92122032ce5b431caf848e99d2c265f8","projectId":"12231893172607086013","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"primary-container\": \"#c5ebd8\",\n              \"on-secondary-container\": \"#445365\",\n              \"surface\": \"#f7f9fb\",\n              \"surface-tint\": \"#436557\",\n              \"surface-container-high\": \"#e1e9ee\",\n              \"secondary-dim\": \"#465467\",\n              \"on-secondary\": \"#f7f9ff\",\n              \"error\": \"#9f403d\",\n              \"surface-container-low\": \"#f0f4f7\",\n              \"secondary-fixed\": \"#d4e4fa\",\n              \"on-error\": \"#fff7f6\",\n              \"on-tertiary-fixed\": \"#424e30\",\n              \"surface-variant\": \"#d9e4ea\",\n              \"outline-variant\": \"#a9b4b9\",\n              \"tertiary-fixed-dim\": \"#ddebc2\",\n              \"on-tertiary\": \"#f0fed5\",\n              \"error-dim\": \"#4e0309\",\n              \"tertiary-dim\": \"#4b5738\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"secondary-container\": \"#d4e4fa\",\n              \"background\": \"#f7f9fb\",\n              \"inverse-surface\": \"#0b0f10\",\n              \"inverse-on-surface\": \"#9a9d9f\",\n              \"secondary-fixed-dim\": \"#c6d6ec\",\n              \"outline\": \"#717c82\",\n              \"on-secondary-fixed\": \"#324052\",\n              \"on-surface\": \"#2a3439\",\n              \"tertiary-container\": \"#ebf9d0\",\n              \"primary-dim\": \"#38594b\",\n              \"primary\": \"#436557\",\n              \"surface-container\": \"#e8eff3\",\n              \"surface-container-highest\": \"#d9e4ea\",\n              \"on-tertiary-container\": \"#546040\",\n              \"on-secondary-fixed-variant\": \"#4e5d6f\",\n              \"primary-fixed-dim\": \"#b8ddca\",\n              \"tertiary-fixed\": \"#ebf9d0\",\n              \"primary-fixed\": \"#c5ebd8\",\n              \"on-error-container\": \"#752121\",\n              \"secondary\": \"#526073\",\n              \"inverse-primary\": \"#d3f9e6\",\n              \"error-container\": \"#fe8983\",\n              \"on-surface-variant\": \"#566166\",\n              \"surface-dim\": \"#cfdce3\",\n              \"on-tertiary-fixed-variant\": \"#5e6a4a\",\n              \"tertiary\": \"#576343\",\n              \"surface-bright\": \"#f7f9fb\",\n              \"on-background\": \"#2a3439\",\n              \"on-primary-container\": \"#37584a\",\n              \"on-primary\": \"#dfffef\",\n              \"on-primary-fixed-variant\": \"#416254\",\n              \"on-primary-fixed\": \"#244638\"\n            },\n            fontFamily: {\n              \"headline\": [\"Manrope\", \"sans-serif\"],\n              \"body\": [\"Inter\", \"sans-serif\"],\n              \"label\": [\"Inter\", \"sans-serif\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        body {\n            background-color: #000000;\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"antialiased overflow-hidden selection:bg-primary selection:text-white\">\n<!-- TopAppBar Fragment as mandated by JSON Logic (suppressed if transactional/linear, but we execute style keys if present) -->\n<!-- JSON specified TopAppBar with leading icon 'close' and bg-black -->\n<header class=\"w-full pt-4 flex justify-start px-6 fixed top-0 left-0 z-50\">\n<button class=\"text-neutral-400 hover:opacity-80 transition-opacity duration-300\">\n<span class=\"material-symbols-outlined text-[32px]\">close</span>\n</button>\n</header>\n<main class=\"relative h-screen w-full flex flex-col items-center justify-center bg-black px-6\">\n<!-- Timer Visual: Minimalist Pie-Chart Style -->\n<div class=\"mb-12 relative flex items-center justify-center\">\n<svg class=\"w-24 h-24 transform -rotate-90\">\n<!-- Background Circle (Thin White Stroke) -->\n<circle cx=\"48\" cy=\"48\" fill=\"transparent\" r=\"40\" stroke=\"rgba(255, 255, 255, 0.1)\" stroke-width=\"2\"></circle>\n<!-- Active Progress (Partial Fill) -->\n<circle cx=\"48\" cy=\"48\" fill=\"transparent\" r=\"40\" stroke=\"white\" stroke-dasharray=\"251.2\" stroke-dashoffset=\"180\" stroke-linecap=\"round\" stroke-width=\"3\"></circle>\n</svg>\n<div class=\"absolute inset-0 flex items-center justify-center\">\n<div class=\"w-1.5 h-1.5 bg-white rounded-full\"></div>\n</div>\n</div>\n<!-- Central Action Typography -->\n<div class=\"text-center max-w-2xl\">\n<h1 class=\"font-headline text-5xl md:text-7xl font-extrabold text-white tracking-tight leading-tight\">\n                1. Grab a trash bag\n            </h1>\n</div>\n<!-- Task Completion Button - High Visibility Fixed at Bottom -->\n<div class=\"fixed bottom-12 left-0 right-0 px-8 flex justify-center\">\n<button class=\"w-full max-w-md bg-primary-container hover:bg-primary text-black font-headline font-extrabold text-xl py-6 rounded-full transition-all duration-300 active:scale-95 shadow-lg shadow-primary/20\">\n                DONE\n            </button>\n</div>\n</main>\n<!-- Content-free, distraction-free environment mandated by task -->\n<!-- Suppression of BottomNavBar and FAB due to \"One Thing Mode\" focus -->\n</body></html>"}
