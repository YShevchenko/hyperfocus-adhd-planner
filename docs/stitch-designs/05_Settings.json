{"screenId":"3f6f663f33d7428f971d77a63d4219bb","projectId":"12231893172607086013","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Settings - The Breathing Canvas</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n    tailwind.config = {\n      darkMode: \"class\",\n      theme: {\n        extend: {\n          colors: {\n            \"surface-container-highest\": \"#dae5de\",\n            \"primary-fixed-dim\": \"#a2e2c5\",\n            \"on-primary-fixed-variant\": \"#27664f\",\n            \"tertiary-dim\": \"#1f5b63\",\n            \"on-tertiary-fixed\": \"#00474e\",\n            \"on-error\": \"#fff7f6\",\n            \"secondary-fixed-dim\": \"#c1dacc\",\n            \"surface-container\": \"#e8f0e9\",\n            \"surface-container-lowest\": \"#ffffff\",\n            \"secondary-container\": \"#cfe9da\",\n            \"primary-fixed\": \"#b0f0d3\",\n            \"on-tertiary\": \"#ebfcff\",\n            \"on-secondary\": \"#e5fff0\",\n            \"on-primary-container\": \"#1c5c46\",\n            \"outline\": \"#737d77\",\n            \"surface-bright\": \"#f6faf6\",\n            \"on-tertiary-container\": \"#1d5961\",\n            \"tertiary-container\": \"#b3ecf6\",\n            \"surface-variant\": \"#dae5de\",\n            \"on-tertiary-fixed-variant\": \"#29636c\",\n            \"on-secondary-fixed-variant\": \"#496055\",\n            \"surface\": \"#f6faf6\",\n            \"on-surface-variant\": \"#57615c\",\n            \"surface-container-low\": \"#eff5ef\",\n            \"on-primary\": \"#e5fff0\",\n            \"secondary-fixed\": \"#cfe9da\",\n            \"error\": \"#a83836\",\n            \"on-secondary-fixed\": \"#2e443a\",\n            \"error-dim\": \"#67040d\",\n            \"surface-tint\": \"#2c6a53\",\n            \"on-secondary-container\": \"#40574c\",\n            \"outline-variant\": \"#aab4ae\",\n            \"tertiary\": \"#2e676f\",\n            \"surface-container-high\": \"#e2eae4\",\n            \"on-surface\": \"#2b3530\",\n            \"error-container\": \"#fa746f\",\n            \"on-error-container\": \"#6e0a12\",\n            \"primary-container\": \"#b0f0d3\",\n            \"primary-dim\": \"#1d5e47\",\n            \"inverse-surface\": \"#0b0f0d\",\n            \"surface-dim\": \"#d2ddd5\",\n            \"secondary\": \"#4d6459\",\n            \"tertiary-fixed-dim\": \"#a5dee7\",\n            \"inverse-on-surface\": \"#999e9a\",\n            \"background\": \"#f6faf6\",\n            \"tertiary-fixed\": \"#b3ecf6\",\n            \"on-primary-fixed\": \"#004934\",\n            \"secondary-dim\": \"#41584d\",\n            \"primary\": \"#2c6a53\",\n            \"inverse-primary\": \"#bbfcde\",\n            \"on-background\": \"#2b3530\"\n          },\n          fontFamily: {\n            \"headline\": [\"Manrope\"],\n            \"body\": [\"Manrope\"],\n            \"label\": [\"Manrope\"]\n          },\n          borderRadius: {\"DEFAULT\": \"0.5rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"2xl\": \"1rem\", \"full\": \"9999px\"},\n        },\n      },\n    }\n  </script>\n<style>\n    body {\n      font-family: 'Manrope', sans-serif;\n      -webkit-tap-highlight-color: transparent;\n    }\n    .premium-gradient {\n      background: linear-gradient(135deg, #2c6a53 0%, #1d5e47 100%);\n    }\n    .glass-nav {\n      backdrop-filter: blur(20px);\n      -webkit-backdrop-filter: blur(20px);\n    }\n    .material-symbols-outlined {\n      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n    }\n  </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface text-on-surface min-h-screen pb-24\">\n<!-- TopAppBar -->\n<header class=\"w-full sticky top-0 z-50 bg-[#f6faf6]/80 dark:bg-[#1a1c1a]/80 backdrop-blur-md\">\n<div class=\"flex items-center px-4 h-16 w-full justify-between\">\n<div class=\"flex items-center gap-4\">\n<button class=\"active:scale-95 transition-transform duration-200 hover:bg-[#e2eae4]/50 p-2 rounded-full\">\n<span class=\"material-symbols-outlined text-[#2c6a53] dark:text-[#8FA89B]\">arrow_back</span>\n</button>\n<h1 class=\"font-['Manrope'] font-bold tracking-tight text-[#2b3530] dark:text-[#e2eae4] text-xl\">Settings</h1>\n</div>\n<div class=\"w-10\"></div> <!-- Spacer for symmetry -->\n</div>\n</header>\n<main class=\"px-6 py-8 space-y-12 max-w-md mx-auto\">\n<!-- Time Blindness Audio Chime Section -->\n<section>\n<div class=\"flex flex-col gap-2 mb-6\">\n<h2 class=\"text-on-surface font-bold text-lg tracking-tight\">Time Blindness Audio Chime</h2>\n<p class=\"text-on-surface-variant text-sm leading-relaxed\">Gentle auditory anchors to keep you present throughout the day.</p>\n</div>\n<div class=\"bg-surface-container-low rounded-xl overflow-hidden\">\n<!-- 5 Mins Toggle -->\n<div class=\"flex items-center justify-between px-6 py-5 bg-surface-container-lowest\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-primary\">timer</span>\n<span class=\"font-medium text-on-surface\">5 mins</span>\n</div>\n<button class=\"w-12 h-6 bg-primary rounded-full relative transition-colors duration-200\">\n<div class=\"absolute right-1 top-1 w-4 h-4 bg-on-primary rounded-full\"></div>\n</button>\n</div>\n<!-- 10 Mins Toggle -->\n<div class=\"flex items-center justify-between px-6 py-5 mt-[2px] bg-surface-container-lowest\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">timer_10</span>\n<span class=\"font-medium text-on-surface\">10 mins</span>\n</div>\n<button class=\"w-12 h-6 bg-surface-container-highest rounded-full relative transition-colors duration-200\">\n<div class=\"absolute left-1 top-1 w-4 h-4 bg-outline-variant rounded-full\"></div>\n</button>\n</div>\n<!-- 15 Mins Toggle -->\n<div class=\"flex items-center justify-between px-6 py-5 mt-[2px] bg-surface-container-lowest\">\n<div class=\"flex items-center gap-4\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">alarm</span>\n<span class=\"font-medium text-on-surface\">15 mins</span>\n</div>\n<button class=\"w-12 h-6 bg-surface-container-highest rounded-full relative transition-colors duration-200\">\n<div class=\"absolute left-1 top-1 w-4 h-4 bg-outline-variant rounded-full\"></div>\n</button>\n</div>\n</div>\n</section>\n<!-- Premium Unlock (Bento Style Hero) -->\n<section class=\"relative\">\n<div class=\"premium-gradient p-8 rounded-2xl shadow-[0_12_32px_rgba(43,53,48,0.1)] relative overflow-hidden group\">\n<!-- Abstract Decorative Background -->\n<div class=\"absolute top-0 right-0 w-32 h-32 bg-primary-fixed-dim/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2\"></div>\n<div class=\"relative z-10 flex flex-col gap-6\">\n<div class=\"space-y-2\">\n<span class=\"bg-primary-fixed/20 text-primary-fixed px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest\">Premium</span>\n<h2 class=\"text-on-primary text-2xl font-extrabold leading-tight\">Unlock Infinite Focus</h2>\n</div>\n<div class=\"flex items-start gap-4\">\n<div class=\"bg-on-primary/10 p-2 rounded-lg\">\n<span class=\"material-symbols-outlined text-on-primary\" data-weight=\"fill\">auto_awesome</span>\n</div>\n<div>\n<p class=\"text-on-primary/90 font-medium leading-relaxed\">Access 300+ overwhelming task templates</p>\n<p class=\"text-on-primary/70 text-sm mt-1\">Break down big goals into tiny, manageable steps.</p>\n</div>\n</div>\n<div class=\"mt-4 flex items-center justify-between\">\n<div class=\"flex flex-col\">\n<span class=\"text-on-primary/60 text-xs uppercase tracking-tighter\">One-time upgrade</span>\n<span class=\"text-on-primary text-2xl font-bold\">$4.99</span>\n</div>\n<button class=\"bg-surface-container-lowest text-primary-dim px-6 py-3 rounded-lg font-bold shadow-lg active:scale-95 transition-all\">\n              Upgrade Now\n            </button>\n</div>\n</div>\n<!-- Visual Element -->\n<div class=\"absolute bottom-[-20%] right-[-10%] opacity-10\">\n<span class=\"material-symbols-outlined text-[120px]\" data-weight=\"fill\">layers</span>\n</div>\n</div>\n</section>\n<!-- Secondary Settings List -->\n<section class=\"space-y-2\">\n<h3 class=\"text-on-surface-variant font-bold text-xs uppercase tracking-[0.2em] px-2 mb-4\">Account</h3>\n<div class=\"flex items-center gap-4 px-4 py-4 hover:bg-surface-container-high rounded-xl transition-colors\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">person</span>\n<span class=\"flex-1 font-medium\">Profile Preferences</span>\n<span class=\"material-symbols-outlined text-outline-variant text-sm\">chevron_right</span>\n</div>\n<div class=\"flex items-center gap-4 px-4 py-4 hover:bg-surface-container-high rounded-xl transition-colors\">\n<span class=\"material-symbols-outlined text-on-surface-variant\">notifications</span>\n<span class=\"flex-1 font-medium\">Notification Style</span>\n<span class=\"material-symbols-outlined text-outline-variant text-sm\">chevron_right</span>\n</div>\n<div class=\"flex items-center gap-4 px-4 py-4 hover:bg-surface-container-high rounded-xl transition-colors\">\n<span class=\"material-symbols-outlined text-error\">logout</span>\n<span class=\"flex-1 font-medium text-error\">Sign Out</span>\n</div>\n</section>\n</main>\n<!-- BottomNavBar -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 bg-[#f6faf6]/80 dark:bg-[#1a1c1a]/80 backdrop-blur-md shadow-[0_-4px_24px_rgba(43,53,48,0.04)] rounded-t-2xl\">\n<div class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-2 py-3 pb-safe\">\n<a class=\"flex flex-col items-center justify-center text-[#57615c] dark:text-[#aeb5b0] px-4 py-1 hover:text-[#2c6a53] transition-all active:scale-90 duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\">center_focus_strong</span>\n<span class=\"font-['Manrope'] text-[11px] font-medium tracking-wide\">Focus</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#57615c] dark:text-[#aeb5b0] px-4 py-1 hover:text-[#2c6a53] transition-all active:scale-90 duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\">self_care</span>\n<span class=\"font-['Manrope'] text-[11px] font-medium tracking-wide\">Rituals</span>\n</a>\n<a class=\"flex flex-col items-center justify-center text-[#57615c] dark:text-[#aeb5b0] px-4 py-1 hover:text-[#2c6a53] transition-all active:scale-90 duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\">layers</span>\n<span class=\"font-['Manrope'] text-[11px] font-medium tracking-wide\">Templates</span>\n</a>\n<a class=\"flex flex-col items-center justify-center bg-[#8FA89B]/20 dark:bg-[#2c6a53]/30 text-[#2c6a53] dark:text-[#8FA89B] rounded-xl px-4 py-1 active:scale-90 transition-transform duration-150\" href=\"#\">\n<span class=\"material-symbols-outlined\">settings</span>\n<span class=\"font-['Manrope'] text-[11px] font-medium tracking-wide\">Settings</span>\n</a>\n</div>\n</nav>\n</body></html>"}
