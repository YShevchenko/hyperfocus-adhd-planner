{"screenId":"a9d51405b5964e67ba248490c9b0b02b","projectId":"12231893172607086013","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>The Digital Sanctuary - Focus</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Inter:wght@300;400;500&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"error-dim\": \"#4e0309\",\n              \"surface-dim\": \"#cfdce3\",\n              \"on-secondary-container\": \"#445365\",\n              \"secondary-fixed\": \"#d4e4fa\",\n              \"primary-dim\": \"#38594b\",\n              \"on-surface\": \"#2a3439\",\n              \"tertiary-fixed-dim\": \"#ddebc2\",\n              \"primary\": \"#436557\",\n              \"surface-container-low\": \"#f0f4f7\",\n              \"on-secondary-fixed-variant\": \"#4e5d6f\",\n              \"surface-bright\": \"#f7f9fb\",\n              \"surface-container\": \"#e8eff3\",\n              \"outline\": \"#717c82\",\n              \"secondary-dim\": \"#465467\",\n              \"surface-variant\": \"#d9e4ea\",\n              \"error\": \"#9f403d\",\n              \"outline-variant\": \"#a9b4b9\",\n              \"inverse-surface\": \"#0b0f10\",\n              \"on-primary-container\": \"#37584a\",\n              \"on-primary\": \"#dfffef\",\n              \"on-error-container\": \"#752121\",\n              \"surface-container-highest\": \"#d9e4ea\",\n              \"error-container\": \"#fe8983\",\n              \"primary-fixed-dim\": \"#b8ddca\",\n              \"inverse-primary\": \"#d3f9e6\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"surface\": \"#f7f9fb\",\n              \"on-primary-fixed\": \"#244638\",\n              \"on-primary-fixed-variant\": \"#416254\",\n              \"on-background\": \"#2a3439\",\n              \"background\": \"#f7f9fb\",\n              \"tertiary-container\": \"#ebf9d0\",\n              \"on-tertiary\": \"#f0fed5\",\n              \"primary-fixed\": \"#c5ebd8\",\n              \"on-tertiary-fixed-variant\": \"#5e6a4a\",\n              \"on-surface-variant\": \"#566166\",\n              \"tertiary-dim\": \"#4b5738\",\n              \"tertiary-fixed\": \"#ebf9d0\",\n              \"on-tertiary-container\": \"#546040\",\n              \"tertiary\": \"#576343\",\n              \"surface-container-high\": \"#e1e9ee\",\n              \"on-error\": \"#fff7f6\",\n              \"on-tertiary-fixed\": \"#424e30\",\n              \"secondary-fixed-dim\": \"#c6d6ec\",\n              \"primary-container\": \"#c5ebd8\",\n              \"surface-tint\": \"#436557\",\n              \"on-secondary-fixed\": \"#324052\",\n              \"secondary\": \"#526073\",\n              \"on-secondary\": \"#f7f9ff\",\n              \"secondary-container\": \"#d4e4fa\",\n              \"inverse-on-surface\": \"#9a9d9f\"\n            },\n            fontFamily: {\n              \"headline\": [\"Manrope\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Inter\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n        }\n        .tonal-transition {\n            background: linear-gradient(to bottom, var(--tw-bg-opacity, 1) rgba(247, 249, 251, 1), rgba(247, 249, 251, 0));\n        }\n        .glass-input:focus {\n            outline: none;\n            box-shadow: 0 0 0 1px rgba(67, 101, 87, 0.1);\n        }\n    </style>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container\">\n<!-- TopAppBar Navigation Shell -->\n<header class=\"fixed top-0 w-full z-50 bg-[#f7f9fb]/80 backdrop-blur-md flex justify-between items-center px-6 h-16 w-full\">\n<div class=\"flex items-center gap-2\">\n<span class=\"material-symbols-outlined text-[#436557]\">notes</span>\n</div>\n<h1 class=\"font-headline tracking-tight text-lg font-semibold text-[#2a3439]\">The Digital Sanctuary</h1>\n<div class=\"w-6\"></div> <!-- Spacer for center alignment -->\n</header>\n<main class=\"min-h-screen flex flex-col items-center justify-center px-8 pt-20 pb-32\">\n<!-- Minimal Background Decorative Element -->\n<div class=\"absolute inset-0 pointer-events-none overflow-hidden\">\n<div class=\"absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-primary-fixed/20 blur-[120px] rounded-full\"></div>\n<div class=\"absolute -bottom-[10%] -right-[10%] w-[50%] h-[50%] bg-secondary-fixed/20 blur-[120px] rounded-full\"></div>\n</div>\n<!-- Central Input Area -->\n<div class=\"w-full max-w-md space-y-12 relative z-10\">\n<div class=\"space-y-6\">\n<textarea autofocus=\"\" class=\"w-full min-h-[280px] bg-transparent border-none focus:ring-0 text-3xl md:text-4xl font-headline font-light tracking-tight text-on-surface placeholder:text-on-surface-variant/40 resize-none p-0\" placeholder=\"What is overwhelming you right now?\"></textarea>\n<!-- Underline Detail following Design System \"Ghost Border\" logic -->\n<div class=\"h-[1px] w-full bg-outline-variant/20\"></div>\n</div>\n<!-- Footer Action Group -->\n<div class=\"flex flex-col items-center space-y-4\">\n<!-- Primary Action (Appears when text is typed - mock visible state) -->\n<button class=\"px-10 py-4 bg-gradient-to-r from-primary to-primary-dim text-on-primary rounded-full font-label font-medium tracking-wide shadow-sm hover:opacity-90 transition-opacity active:scale-95 duration-300\">\n                    Release thoughts\n                </button>\n<!-- Secondary Action -->\n<button class=\"px-6 py-3 text-on-surface-variant/70 hover:text-primary transition-colors font-label text-sm tracking-wide\">\n                    Or browse templates\n                </button>\n</div>\n</div>\n<!-- Contextual Subtle Tip -->\n<div class=\"fixed bottom-32 w-full text-center px-8\">\n<p class=\"text-xs font-label text-on-surface-variant/40 uppercase tracking-[0.2em]\">Take a deep breath. Focus on the words.</p>\n</div>\n</main>\n<!-- BottomNavBar (Only Icons version) -->\n<nav class=\"fixed bottom-0 left-0 w-full z-50 bg-[#f7f9fb]/80 backdrop-blur-md flex justify-around items-center px-8 pb-8 pt-4 rounded-t-[1.5rem] shadow-[0px_-12px_32px_rgba(42,52,57,0.05)]\">\n<!-- Active Tab: auto_awesome (Focus/Entry) -->\n<a class=\"flex flex-col items-center justify-center bg-[#c5ebd8] text-[#436557] rounded-full p-3 transition-transform duration-300 active:scale-95\" href=\"#\">\n<span class=\"material-symbols-outlined\" style=\"font-variation-settings: 'FILL' 1;\">auto_awesome</span>\n</a>\n<!-- Inactive Tab: spa -->\n<a class=\"flex flex-col items-center justify-center text-[#566166] p-3 hover:bg-[#f0f4f7] rounded-full transition-colors\" href=\"#\">\n<span class=\"material-symbols-outlined\">spa</span>\n</a>\n<!-- Inactive Tab: person -->\n<a class=\"flex flex-col items-center justify-center text-[#566166] p-3 hover:bg-[#f0f4f7] rounded-full transition-colors\" href=\"#\">\n<span class=\"material-symbols-outlined\">person</span>\n</a>\n</nav>\n<!-- Decorative Floating Element -->\n<div class=\"fixed top-1/4 -right-12 w-24 h-24 opacity-20 pointer-events-none\">\n<img alt=\"\" class=\"w-full h-full object-contain\" data-alt=\"a single soft focus sage green leaf with intricate veins on a pure white minimalist background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBei-8dNJ3-haj5gPxLqLioKyjr5F2mj7pcruWc7R0f06n6ljel5Ix9sliNeEDiPH9ciQhrQRZmr-WklmizAKBtbd57wz6MmnSeiDVWZgquPkmOrRd6IFb_OzJzO4GR0vmSx391At-Y5ahbvT5iZOG9nDHrqVaLE9wqaxbSNPsUDscGZFzQKrMqoIZJPls5ECgOolgMGbMU37tie1K-ZP6vmm2YycW4dA-_8S5WIXZoFIu6YCIZj35gs8KSFj2pROudZSCEzSnefweP\"/>\n</div>\n</body></html>"}
