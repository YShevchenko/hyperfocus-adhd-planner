{"screenId":"4707d9e4e538491aa18812eab877afb6","projectId":"12231893172607086013","htmlContent":"<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@200;400;700;800&amp;family=Inter:wght@300;400;500;600&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n    tailwind.config = {\n      darkMode: \"class\",\n      theme: {\n        extend: {\n          colors: {\n            \"on-surface\": \"#2a3439\",\n            \"error-container\": \"#fe8983\",\n            \"on-error-container\": \"#752121\",\n            \"error\": \"#9f403d\",\n            \"tertiary\": \"#576343\",\n            \"primary-dim\": \"#38594b\",\n            \"on-primary-container\": \"#37584a\",\n            \"secondary-dim\": \"#465467\",\n            \"inverse-on-surface\": \"#9a9d9f\",\n            \"surface-bright\": \"#f7f9fb\",\n            \"on-secondary-fixed-variant\": \"#4e5d6f\",\n            \"secondary\": \"#526073\",\n            \"on-tertiary-fixed-variant\": \"#5e6a4a\",\n            \"tertiary-fixed-dim\": \"#ddebc2\",\n            \"tertiary-container\": \"#ebf9d0\",\n            \"surface-container-lowest\": \"#ffffff\",\n            \"on-tertiary-container\": \"#546040\",\n            \"secondary-container\": \"#d4e4fa\",\n            \"surface-container-high\": \"#e1e9ee\",\n            \"surface-container-highest\": \"#d9e4ea\",\n            \"on-primary-fixed\": \"#244638\",\n            \"on-primary\": \"#dfffef\",\n            \"surface\": \"#f7f9fb\",\n            \"primary-fixed\": \"#c5ebd8\",\n            \"on-error\": \"#fff7f6\",\n            \"primary-container\": \"#c5ebd8\",\n            \"background\": \"#f7f9fb\",\n            \"on-tertiary\": \"#f0fed5\",\n            \"on-tertiary-fixed\": \"#424e30\",\n            \"surface-variant\": \"#d9e4ea\",\n            \"secondary-fixed-dim\": \"#c6d6ec\",\n            \"on-background\": \"#2a3439\",\n            \"outline-variant\": \"#a9b4b9\",\n            \"secondary-fixed\": \"#d4e4fa\",\n            \"tertiary-fixed\": \"#ebf9d0\",\n            \"on-secondary-fixed\": \"#324052\",\n            \"on-primary-fixed-variant\": \"#416254\",\n            \"inverse-surface\": \"#0b0f10\",\n            \"surface-dim\": \"#cfdce3\",\n            \"tertiary-dim\": \"#4b5738\",\n            \"on-surface-variant\": \"#566166\",\n            \"on-secondary\": \"#f7f9ff\",\n            \"surface-container-low\": \"#f0f4f7\",\n            \"primary-fixed-dim\": \"#b8ddca\",\n            \"on-secondary-container\": \"#445365\",\n            \"inverse-primary\": \"#d3f9e6\",\n            \"outline\": \"#717c82\",\n            \"primary\": \"#436557\",\n            \"surface-tint\": \"#436557\",\n            \"surface-container\": \"#e8eff3\",\n            \"error-dim\": \"#4e0309\"\n          },\n          fontFamily: {\n            \"headline\": [\"Manrope\"],\n            \"body\": [\"Inter\"],\n            \"label\": [\"Inter\"]\n          },\n          borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n        },\n      },\n    }\n  </script>\n<style>\n    .material-symbols-outlined {\n      font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;\n    }\n    body {\n      background-color: #f7f9fb;\n      color: #2a3439;\n    }\n  </script>\n<style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head>\n<body class=\"font-body selection:bg-primary-container selection:text-on-primary-container\">\n\n  <!-- TopAppBar -->\n  <header class=\"fixed top-0 w-full z-50 bg-[#f7f9fb]/80 backdrop-blur-md\">\n    <div class=\"flex items-center justify-between px-6 py-4 w-full\">\n      <div class=\"flex items-center gap-2\">\n        <span class=\"material-symbols-outlined text-[#436557]\" data-icon=\"spa\">spa</span>\n        <h1 class=\"font-['Manrope'] font-black tracking-tighter text-[#436557] text-lg\">Clean Kitchen</h1>\n      </div>\n      <div class=\"flex items-center gap-4\">\n        <span class=\"material-symbols-outlined text-[#566166] hover:opacity-70 transition-opacity cursor-pointer\" data-icon=\"search\">search</span>\n        <div class=\"w-8 h-8 rounded-full bg-surface-container-high overflow-hidden\">\n          <img src=\"https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=100\" data-alt=\"portrait of a calm person in a natural light setting with a soft neutral background\" class=\"w-full h-full object-cover\">\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"pt-24 pb-48 px-6 max-w-lg mx-auto\">\n    <!-- Hero Editorial Section -->\n    <section class=\"mb-12\">\n      <span class=\"text-primary font-headline font-bold text-xs tracking-[0.2em] uppercase mb-2 block\">Today's Ritual</span>\n      <h2 class=\"font-headline text-4xl font-extrabold tracking-tight leading-tight text-on-surface mb-4\">Focus on the <br>small things.</h2>\n      <p class=\"text-on-surface-variant text-md font-light leading-relaxed\">A clear space leads to a clear mind. Complete these micro-actions to restore balance.</p>\n    </section>\n\n    <!-- Micro-steps List -->\n    <section class=\"space-y-4\">\n      <!-- Step 1 -->\n      <div class=\"bg-surface-container-lowest p-5 rounded-xl shadow-[0px_12px_32px_rgba(42,52,57,0.03)] flex items-center justify-between group hover:bg-surface-container-low transition-colors duration-300\">\n        <div class=\"flex items-center gap-4\">\n          <div class=\"w-6 h-6 rounded-lg border-[1.5px] border-outline-variant/30 flex items-center justify-center text-transparent group-hover:border-primary/50 transition-all\">\n            <span class=\"material-symbols-outlined text-[16px]\" data-icon=\"check\">check</span>\n          </div>\n          <span class=\"text-on-surface font-medium text-[15px]\">Grab a trash bag</span>\n        </div>\n        <span class=\"material-symbols-outlined text-outline-variant/40\" data-icon=\"delete_outline\">delete_outline</span>\n      </div>\n\n      <!-- Step 2 -->\n      <div class=\"bg-surface-container-lowest p-5 rounded-xl shadow-[0px_12px_32px_rgba(42,52,57,0.03)] flex items-center justify-between group hover:bg-surface-container-low transition-colors duration-300\">\n        <div class=\"flex items-center gap-4\">\n          <div class=\"w-6 h-6 rounded-lg border-[1.5px] border-outline-variant/30 flex items-center justify-center text-transparent group-hover:border-primary/50 transition-all\">\n            <span class=\"material-symbols-outlined text-[16px]\" data-icon=\"check\">check</span>\n          </div>\n          <span class=\"text-on-surface font-medium text-[15px]\">Pick up visible trash</span>\n        </div>\n        <span class=\"material-symbols-outlined text-outline-variant/40\" data-icon=\"clean_hands\">clean_hands</span>\n      </div>\n\n      <!-- Step 3 -->\n      <div class=\"bg-surface-container-lowest p-5 rounded-xl shadow-[0px_12px_32px_rgba(42,52,57,0.03)] flex items-center justify-between group hover:bg-surface-container-low transition-colors duration-300\">\n        <div class=\"flex items-center gap-4\">\n          <div class=\"w-6 h-6 rounded-lg border-[1.5px] border-outline-variant/30 flex items-center justify-center text-transparent group-hover:border-primary/50 transition-all\">\n            <span class=\"material-symbols-outlined text-[16px]\" data-icon=\"check\">check</span>\n          </div>\n          <span class=\"text-on-surface font-medium text-[15px]\">Clear the counters</span>\n        </div>\n        <span class=\"material-symbols-outlined text-outline-variant/40\" data-icon=\"table_bar\">table_bar</span>\n      </div>\n\n      <!-- Step 4 -->\n      <div class=\"bg-surface-container-lowest p-5 rounded-xl shadow-[0px_12px_32px_rgba(42,52,57,0.03)] flex items-center justify-between group hover:bg-surface-container-low transition-colors duration-300\">\n        <div class=\"flex items-center gap-4\">\n          <div class=\"w-6 h-6 rounded-lg border-[1.5px] border-outline-variant/30 flex items-center justify-center text-transparent group-hover:border-primary/50 transition-all\">\n            <span class=\"material-symbols-outlined text-[16px]\" data-icon=\"check\">check</span>\n          </div>\n          <span class=\"text-on-surface font-medium text-[15px]\">Load the dishwasher</span>\n        </div>\n        <span class=\"material-symbols-outlined text-outline-variant/40\" data-icon=\"dishwasher_gen\">dishwasher_gen</span>\n      </div>\n\n      <!-- Step 5 -->\n      <div class=\"bg-surface-container-lowest p-5 rounded-xl shadow-[0px_12px_32px_rgba(42,52,57,0.03)] flex items-center justify-between group hover:bg-surface-container-low transition-colors duration-300\">\n        <div class=\"flex items-center gap-4\">\n          <div class=\"w-6 h-6 rounded-lg border-[1.5px] border-outline-variant/30 flex items-center justify-center text-transparent group-hover:border-primary/50 transition-all\">\n            <span class=\"material-symbols-outlined text-[16px]\" data-icon=\"check\">check</span>\n          </div>\n          <span class=\"text-on-surface font-medium text-[15px]\">Wipe the sink</span>\n        </div>\n        <span class=\"material-symbols-outlined text-outline-variant/40\" data-icon=\"opacity\">opacity</span>\n      </div>\n    </section>\n\n    <!-- Aesthetic Filler / Context -->\n    <div class=\"mt-12 opacity-40\">\n      <div class=\"h-[200px] rounded-3xl overflow-hidden bg-surface-container\">\n        <img src=\"https://images.unsplash.com/photo-1556911220-e15b29be8c8f?auto=format&fit=crop&q=80&w=800\" data-alt=\"minimalist white kitchen with natural sunlight falling on a clean wooden countertop and a single green plant\" class=\"w-full h-full object-cover grayscale brightness-110 contrast-75\">\n      </div>\n    </div>\n  </main>\n\n  <!-- Action Area -->\n  <div class=\"fixed bottom-24 left-0 w-full px-6 z-40\">\n    <button class=\"w-full py-5 bg-secondary text-on-secondary rounded-full font-headline font-bold text-lg shadow-xl hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-3\">\n      <span class=\"material-symbols-outlined\" data-icon=\"timer\">timer</span>\n      Start One Thing Mode\n    </button>\n  </div>\n\n  <!-- BottomNavBar -->\n  <nav class=\"fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-[#f7f9fb]/80 backdrop-blur-md rounded-t-[1.5rem] shadow-[0px_-12px_32px_rgba(42,52,57,0.05)] z-50\">\n    <div class=\"flex flex-col items-center justify-center bg-[#c5ebd8] text-[#2a3439] rounded-full px-5 py-1 transition-transform duration-300 scale-98\">\n      <span class=\"material-symbols-outlined\" data-icon=\"filter_vintage\" style=\"font-variation-settings: 'FILL' 1;\">filter_vintage</span>\n      <span class=\"font-['Inter'] text-[10px] font-medium lowercase tracking-wide\">focus</span>\n    </div>\n    <div class=\"flex flex-col items-center justify-center text-[#566166] opacity-60 hover:bg-[#f0f4f7] transition-colors duration-300 rounded-full px-5 py-1\">\n      <span class=\"material-symbols-outlined\" data-icon=\"tempest\">tempest</span>\n      <span class=\"font-['Inter'] text-[10px] font-medium lowercase tracking-wide\">rituals</span>\n    </div>\n    <div class=\"flex flex-col items-center justify-center text-[#566166] opacity-60 hover:bg-[#f0f4f7] transition-colors duration-300 rounded-full px-5 py-1\">\n      <span class=\"material-symbols-outlined\" data-icon=\"inventory_2\">inventory_2</span>\n      <span class=\"font-['Inter'] text-[10px] font-medium lowercase tracking-wide\">pantry</span>\n    </div>\n    <div class=\"flex flex-col items-center justify-center text-[#566166] opacity-60 hover:bg-[#f0f4f7] transition-colors duration-300 rounded-full px-5 py-1\">\n      <span class=\"material-symbols-outlined\" data-icon=\"self_improvement\">self_improvement</span>\n      <span class=\"font-['Inter'] text-[10px] font-medium lowercase tracking-wide\">peace</span>\n    </div>\n  </nav>\n\n</body>\n</html></style><style>\n    body {\n      min-height: max(884px, 100dvh);\n    }\n  </style>\n  </head><body></body></html>"}
